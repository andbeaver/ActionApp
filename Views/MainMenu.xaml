<UserControl x:Class="ActionApp.Views.MainMenu"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ActionApp.Views"
        mc:Ignorable="d"
        DataContext="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}">

    <Border Background="{StaticResource PrimaryBrush}" Padding="16,0">
        <DockPanel Height="52">

            <!-- App title -->
            <TextBlock Text="Action Movies DB"
                       Foreground="White"
                       FontSize="18"
                       FontWeight="Bold"
                       VerticalAlignment="Center"
                       DockPanel.Dock="Left"/>

            <!-- Exit button -->
            <Button Content="Exit"
                    Command="{Binding ExitCommand}"
                    Style="{StaticResource NavButtonStyle}"
                    DockPanel.Dock="Right"
                    Foreground="#EF4444"/>

            <!-- Nav buttons -->
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                <Button Content="Home" Command="{Binding NavToHomeCommand}" Style="{StaticResource NavButtonStyle}"/>
                <Button Content="Movies" Command="{Binding NavToMoviesCommand}" Style="{StaticResource NavButtonStyle}"/>
                <Button Content="Actors" Command="{Binding NavToActorsCommand}" Style="{StaticResource NavButtonStyle}"/>
                <Button Content="Directors" Command="{Binding NavToDirectorsCommand}" Style="{StaticResource NavButtonStyle}"/>
            </StackPanel>

        </DockPanel>
    </Border>

</UserControl>