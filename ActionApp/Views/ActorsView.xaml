<UserControl x:Class="ActionApp.Views.ActorsView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:ActionApp.Views"
      xmlns:vm="clr-namespace:ActionApp.ViewModels"
      mc:Ignorable="d"
      d:DesignHeight="450" d:DesignWidth="800">

    <Grid Background="{StaticResource LightBgBrush}" Margin="24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Page title -->
        <TextBlock Grid.Row="0" Text="Actors" Style="{StaticResource PageTitleStyle}"/>

        <!-- Search bar and filter button -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,16">
            <Grid>
                <TextBox Width="400"
                         Style="{StaticResource SearchBoxStyle}"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>
                <TextBlock Text="Search..." Style="{StaticResource PlaceholderStyle}">
                    <TextBlock.Visibility>
                        <Binding Path="SearchText" Converter="{x:Null}" FallbackValue="Visible"/>
                    </TextBlock.Visibility>
                </TextBlock>
            </Grid>
            <Button Content="Filter / Sort" Style="{StaticResource FilterButtonStyle}" Margin="12,0,0,0"/>
        </StackPanel>

        <!-- Data grid -->
        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding ActorsView}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Name" Binding="{Binding PrimaryName}" Width="*"/>
                <DataGridTextColumn Header="Birth Year" Binding="{Binding BirthYear}" Width="120"/>
                <DataGridTextColumn Header="Top Movie" Binding="{Binding TopMovie}" Width="2*"/>
                <DataGridTextColumn Header="Movies Count" Binding="{Binding MovieCount}" Width="120"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>