<Window xmlns:Services="clr-namespace:ActionApp.Services"
        x:Class="ActionApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ActionApp"
        xmlns:views="clr-namespace:ActionApp.Views"
        mc:Ignorable="d"
        Background="white"
        Title="ActionApp" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Menu Section -->
        <Border Grid.Row="0">
            <views:MainMenu />
        </Border>

        <!-- App Content Section -->
        <Border Grid.Row="1">
            <ContentControl Content="{Binding CurrentViewModel}" />
        </Border>

    </Grid>
</Window>
